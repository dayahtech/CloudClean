<div class="auth-container">
    <div class="logo2">
        <img src="/images/logo.png" alt="CloudClean Logo" class="logo">
        <h1>CloudClean</h1>
    </div>
    <h2>Kindly type your email address to<br><span class="center-text">reset your password</span></h2>
    <% if (errorMessage) { %>
        <div id="error-message" style="color:red; text-align:center; margin-bottom:10px;">
            <%= errorMessage %>
        </div>
    <% } %>
    <form action="/forgot-password" method="POST">
        <input type="email" name="email" id="email" placeholder="Email:" required>

        <div class="links">
            <a href="/signup">Sign Up</a>
            <a href="/login">Back to Login</a>
        </div>

        <button type="submit" class="auth-button">Submit</button>
    </form>
</div>